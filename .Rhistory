setwd("~/GitHub/Attention-Economy-Neuro-Stochastic-Modeling-of-Cognitive-Fragmentation-in-Digital-Interfaces")
setwd("~/GitHub/Attention-Economy-Neuro-Stochastic-Modeling-of-Cognitive-Fragmentation-in-Digital-Interfaces")
source("~/GitHub/Attention-Economy-Neuro-Stochastic-Modeling-of-Cognitive-Fragmentation-in-Digital-Interfaces/montecarlo_ifa_simulation.R", echo = TRUE)
#CARGA DE LIBRERIAS
library(MASS)
library(ggplot2)
library(dplyr)
# LECTURA DE DATOS REALES Y EXTRACCION DE PARAMETROS BIOLOGICOS
datos <- read.csv('estudiantes_clean.csv')
predictores <- c('Daily_Screen_Time_Hours', 'Social_Media_Usage_Hours',
'App_Notifications_Received', 'Screen_Unlocks_Per_Day')
target <- 'IFA'
#Modelamos en escala original para poder extraer KPIs con significado real (horas, clicks)
modelo_real <- lm(IFA ~ Daily_Screen_Time_Hours + Social_Media_Usage_Hours +
App_Notifications_Received + Screen_Unlocks_Per_Day, data = datos)
#Extraemos los coeficientes beta reales (Efectos marginales)
betas <- coef(modelo_real)
sigma_error <- sigma(modelo_real) # Desviación estándar del residuo (ruido gaussiano intrínseco)
#EXTRACCION DE LA ESTRUCTURA CONDUCTUAL REAL (Medias y Covarianzas)
#Esto garantiza que los perfiles simulados respeten las correlaciones reales del estudiante de la UCV
medias_predictores <- colMeans(datos[, predictores])
matriz_covarianza <- cov(datos[, predictores])
#CONFIGURACION DE LA SIMULACION DE MONTECARLO (10,000 ITERACIONES)
set.seed(42) # Reproducibilidad científica
n_iteraciones <- 10000
#Generamos 10,000 perfiles de estudiantes sintéticos pero basados en la matriz real
perfiles_simulados <- mvrnorm(n = n_iteraciones,
mu = medias_predictores,
Sigma = matriz_covarianza)
perfiles_simulados <- as.data.frame(perfiles_simulados)
# Evitamos valores negativos absurdos en la simulación debido a las colas de la distribución
perfiles_simulados <- perfiles_simulados %>%
mutate(across(everything(), ~ ifelse(.x < 0, 0, .x)))
# 5. INYECCION DE RUIDO GAUSSIANO Y PROYECCION DEL IFA
# Agregamos el error estocástico subyacente para simular la variabilidad biológica individual
ruido_gaussiano <- rnorm(n_iteraciones, mean = 0, sd = sigma_error)
perfiles_simulados <- perfiles_simulados %>%
mutate(
IFA_proyectado = betas[1] +
(betas[2] * Daily_Screen_Time_Hours) +
(betas[3] * Social_Media_Usage_Hours) +
(betas[4] * App_Notifications_Received) +
(betas[5] * Screen_Unlocks_Per_Day) +
ruido_gaussiano
)
# Normalizamos el IFA proyectado a una escala 0-100 para que sea entendible
min_ifa <- min(perfiles_simulados$IFA_proyectado)
max_ifa <- max(perfiles_simulados$IFA_proyectado)
perfiles_simulados <- perfiles_simulados %>%
mutate(IFA_score = ((IFA_proyectado - min_ifa) / (max_ifa - min_ifa)) * 100)
#-----------------------------------------------------------------------------
#EXTRACCION DE KPIS DE ALTO IMPACTO PUBLICO ("Popcorn Brain Threshold")
#-------------------------------------------------------------------------
# Definimos el umbral de "Colapso Cognitivo Severo" en el percentil 85 del IFA
umbral_critico <- quantile(perfiles_simulados$IFA_score, 0.85)
# Filtramos el comportamiento de los estudiantes que caen en este colapso
estudiantes_colapsados <- perfiles_simulados %>% filter(IFA_score >= umbral_critico)
media_redes_critica <- mean(estudiantes_colapsados$Social_Media_Usage_Hours)
media_desbloqueos_critica <- mean(estudiantes_colapsados$Screen_Unlocks_Per_Day)
# Mensajes clave para la audiencia
cat("\n================================================================\n")
cat("          KPIS DE RIESGO NEUROCOGNITIVO (MONTECARLO)            \n")
cat("================================================================\n")
cat("1. Umbral crítico de Fragmentación Atencional (0-100):", round(umbral_critico, 2), "puntos.\n")
cat("2. El 15% de la población estudiantil con peor salud atencional promedia:\n")
cat("   ->", round(media_redes_critica, 1), "horas DIARIAS dedicadas exclusivamente a redes sociales.\n")
cat("   ->", round(media_desbloqueos_critica, 0), "desbloqueos de pantalla al día (implicando un shock atencional cada 8-10 minutos).\n")
cat("================================================================\n")
# VISUALIZACION DE DENSIDAD PROBABILISTICA FORMAL
grafico_densidad <- ggplot(perfiles_simulados, aes(x = IFA_score)) +
geom_density(fill = "#4A90E2", alpha = 0.4, color = "#1F4E79", linewidth = 1) +
geom_vline(xintercept = umbral_critico, color = "#D9534F", linetype = "dashed", linewidth = 1.2) +
annotate("text", x = umbral_critico + 8, y = 0.01,
label = paste("ZONA CRÍTICA\n(Popcorn Brain)\n>", round(umbral_critico,0), "puntos"),
color = "#D9534F", fontface = "bold", size = 4) +
labs(
title = "Distribución Probabilística de la Fragmentación Atencional",
subtitle = "Simulación de Montecarlo basada en la estructura de covarianza real (N = 10,000 perfiles)",
x = "Índice de Fragmentación de la Atención (IFA Score: 0 - 100)",
y = "Densidad de Probabilidad (Frecuencia Relativa Estocástica)"
) +
theme_minimal(base_family = "serif") +
theme(
plot.title = element_text(face = "bold", size = 14, color = "#111111"),
plot.subtitle = element_text(size = 10, color = "#555555"),
axis.title = element_text(face = "bold", size = 11),
panel.grid.minor = element_blank()
)
# Guardar el gráfico automáticamente en alta definición para el reporte
ggsave("grafico_montecarlo_density.png", plot = grafico_densidad, width = 8, height = 5, dpi = 300)
print("Simulación completada con éxito y gráfico guardado")
View(datos)
View(estudiantes_colapsados)
View(perfiles_simulados)
View(modelo_real)
View(modelo_real)
View(modelo_real)
View(matriz_covarianza)
View(estudiantes_colapsados)
View(datos)
View(datos)
View(perfiles_simulados)
